# =========================================================
# NETWORK SETTINGS
# =========================================================

HOST = "0.0.0.0"
PORT = 5000

# =========================================================
# LOCAL EXPORT FOLDER
# =========================================================

EXPORT_FOLDER = r"\\Desktop-3jktn8k\sysmex"

# Create folder if it does not exist
os.makedirs(EXPORT_FOLDER, exist_ok=True)

# =========================================================
# DATABASE
# =========================================================

DB_PATH = "lis.db"

conn = sqlite3.connect(DB_PATH, check_same_thread=False)
cursor = conn.cursor()

